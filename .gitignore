# Local configuration
local.properties
ClawApp/local.properties
!ClawApp/local.properties.example

# Release signing keystore (never commit - contains private key)
ClawApp/keystore/*.jks
ClawApp/keystore/*.keystore
!ClawApp/keystore/.gitkeep
!ClawApp/keystore/README.md

# IDE and Android Studio
.idea/
.android/
.android-tmp/
.vscode/

# Gradle and build outputs
**/.gradle/
.gradle-user/
.gradle-tmp/
**/build/
**/app-*/

# Debug and artifact outputs
debug-artifacts/
artifacts/
nb-cache/

# Native and crash artifacts
hs_err_pid*
replay_pid*

# Runtime local artifacts
ClawRuntime/magisk/config/runtime.generated.yaml

# ClawRuntime build outputs (regenerate locally via build-runtime.ps1 / build-magisk.ps1)
# These contain local config (shared secret, signatures) and must not be committed.
ClawRuntime/dist/
ClawRuntime/magisk/bin/

# Logs and temporary outputs
*.log
*.tmp
*.bak

# Python cache
__pycache__/
*.pyc

# Trae local planning artifacts
.trae/
